# This is an example .env file.
# In a real application, you should create a .env file with your actual secrets
# and add it to your .gitignore file.

# Generate a strong secret key using: openssl rand -hex 32
SECRET_KEY="SUPER_SECRET_KEY_CHANGE_ME"

# OpenWeatherMap API key (required for weather features)
# Get one free at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Set the allowed origins for CORS
ALLOWED_ORIGINS="http://localhost:3000"

# Set the environment to "development" or "production"
ENVIRONMENT="development"

# Set to "False" to disable new user registration
ALLOW_REGISTRATION="True"
